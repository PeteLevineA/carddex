{
  "name": "carddex",
  "version": "0.1.0",
  "private": true,
  "description": "Carddex monorepo: web Pokemon card holofoil viewer + iOS app with scanning and identification.",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @carddex/web",
    "build": "npm run build -w @carddex/web",
    "preview": "npm run preview -w @carddex/web",
    "ingest": "npm run ingest -w @carddex/ingest",
    "ingest:static": "npm run ingest:static -w @carddex/ingest",
    "ingest:catalog": "npm run ingest:catalog -w @carddex/ingest",
    "catalog:demo": "npm run catalog:demo -w @carddex/ingest",
    "lint": "echo 'add eslint here'"
  }
}
